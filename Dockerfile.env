
FROM python:3.10-slim
 
RUN apt-get update && apt-get install -y --no-install-recommends \
        default-jdk \
        build-essential \
        git \
        wget \
        curl \
    && rm -rf /var/lib/apt/lists/*
 
ENV JAVA_HOME=/usr/lib/jvm/default-java
ENV PATH="${JAVA_HOME}/bin:${PATH}"
 
WORKDIR /app
 

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir torch==2.3.1 \
    && pip install --no-cache-dir -r requirements.txt \
    && python -c "import spacy" \
    && python -m spacy download en_core_web_sm
 
RUN python -c "from openie import StanfordOpenIE; \
    c=StanfordOpenIE(); print(c.annotate('cats are animals')); c.client.stop()" || \
    echo "CoreNLP pre-cache skipped (will download on first run)"
 
CMD ["/bin/bash"]